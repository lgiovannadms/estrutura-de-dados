package eda;

import java.util.Scanner;

class TrocaVizinhosLinkedList {
	private Node head;
	private Node tail;
	private int size;
	
	Scanner sc = new Scanner(System.in);
	String[] entrada = sc.nextLine().split(" ");
	int index = sc.nextInt();
	
	for (int i = 0; i < entrada.length; i++) {
		addLast(Integer.parseInt(entrada[i]));
	}
	
	trocaVizinhos();
	printLinkedList();
	sc.close();
	
	public void printLinkedList() {
		Node aux = this.head;
		String saida = "";
		while (aux != null) {
			saida += aux.num + " ";
			aux = aux.next;
		}
		System.out.println(saida.trim());
	}
	
	public void addLast(int valor) {
		Node newNode = new Node(valor);
		
		if(isEmpty()) {
			this.head = newNode;
			this.tail = newNode;
		} else {
			this.tail.next = newNode;
			newNode.prev = tail;
			this.tail = newNode;
		}
		
		this.size++;
	}

	public boolean isEmpty() {
		return this.head == null;
	}
	
	public Node get(int index) {
		Node aux = this.head;
		 
		for(int i = 0; i < index; i++) {
			aux = aux.next;
		}
		
		return aux;
	}
	
	public void trocaVizinhos() {
		Node aux = get(index);
		Node vizinho = aux.next;
		
		aux.next = vizinho.next;
		vizinho.next = aux;
		vizinho.prev = aux.prev;
		aux.prev = vizinho;
	}
}


class Node {
	int num;
	Node next;
	Node prev;
	
	public Node(int num) {
		this.num = num;
		this.next = null;
		this.prev = null;
	}
}
}
